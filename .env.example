# Web UI port (default: auto-assign if not set)
OPENWORK_WEB_PORT=5173

# Backend server port (optional)
# OPENWORK_PORT=8787

# Bind host (optional)
# OPENWORK_HOST=0.0.0.0

# RunPod (for MAYA backend on RunPod)
# RUNPOD_API_KEY=your_runpod_api_key
# RUNPOD_ENDPOINT_ID=your_runpod_endpoint_id

# Ngrok (for RunPod: frontend connects to this URL)
# NGROK_AUTHTOKEN=your_ngrok_authtoken
# NGROK_DOMAIN=unameliorative-regretably-kimberly.ngrok-free.dev

# MAYA server token (frontend uses this to connect to ngrok URL)
# MAYA_TOKEN=your_secret_token
